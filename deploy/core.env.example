# Production core install
HALO_SKIP_BUILD=1
HALO_START_SERVICE=1

# Paths
HALO_INSTALL_PREFIX=/opt/halo
HALO_CONFIG_DIR=/etc/halo
HALO_DATA_DIR=/var/lib/halo
HALO_SYSTEMD_DIR=/etc/systemd/system

# Service
HALO_CORE_SERVICE_NAME=halo-core.service
HALO_CORE_USER=halo
HALO_CORE_GROUP=halo
HALO_CORE_LISTEN=:7310

# Install behavior
HALO_REGISTER_SERVICE=1
HALO_ENABLE_SERVICE=1
HALO_FORCE_CONFIG=0
