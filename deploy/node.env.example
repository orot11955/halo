# Production node install
HALO_SKIP_BUILD=1
HALO_START_SERVICE=1

# Identity and auth
HALO_NODE_NAME=node-1
HALO_NODE_TOKEN=replace-with-issued-token

# Paths
HALO_INSTALL_PREFIX=/opt/halo
HALO_CONFIG_DIR=/etc/halo
HALO_DATA_DIR=/var/lib/halo
HALO_SYSTEMD_DIR=/etc/systemd/system

# Service
HALO_NODE_SERVICE_NAME=halo-node.service
HALO_NODE_USER=root
HALO_NODE_GROUP=root
HALO_NODE_LISTEN=:7311

# Node features
HALO_NODE_ENABLE_LOGS=true
HALO_NODE_ENABLE_CONTAINERS=true
HALO_NODE_ENABLE_PORTS=true
HALO_NODE_MAX_LOG_TAIL=200
HALO_NODE_ALLOWED_JOURNAL_UNITS=

# Install behavior
HALO_REGISTER_SERVICE=1
HALO_ENABLE_SERVICE=1
HALO_FORCE_CONFIG=0
